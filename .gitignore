# ============================================================
# LBS Generative AI Project - initial .gitignore
# For React/Vite + Node.js backend + Prisma + PostgreSQL
# ============================================================

# ------------------------------------------------------------
# Secrets and local environment files
# Never commit API keys, Auth0 values, database URLs, tokens, or passwords.
# ------------------------------------------------------------
.env
.env.*
*.pem
*.key
*.crt
*.p12
*.pfx
*.token
*.secret
secrets/
.secret/

# If renamed starter env files are accidentally placed in the repo, keep them out of Git as well.
LBS_GROUP_STARTER.env
*GROUP*.env
*group*.env

# ------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------
node_modules/
.pnp/
.pnp.js
.pnpm-store/
jspm_packages/
bower_components/

# ------------------------------------------------------------
# Build outputs and generated assets
# ------------------------------------------------------------
dist/
build/
out/
.output/
.next/
.nuxt/
.svelte-kit/
.vite/
.vitepress/dist/
.vitepress/cache/
coverage/
.nyc_output/
lib-cov/

# ------------------------------------------------------------
# Logs and runtime files
# ------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.pid
*.pid.lock
*.seed

# ------------------------------------------------------------
# Caches
# ------------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/
.swc/
.rollup.cache/

# ------------------------------------------------------------
# TypeScript
# ------------------------------------------------------------
*.tsbuildinfo

# ------------------------------------------------------------
# Prisma and local database artifacts
# Keep schema and migrations committed.
# Do not commit local database dumps or generated local DB files.
# ------------------------------------------------------------
*.db
*.db-journal
*.sqlite
*.sqlite3
*.dump
*.sql.gz
*.backup
prisma/dev.db
prisma/dev.db-journal

# ------------------------------------------------------------
# PostgreSQL local data directories, if Codex creates one
# ------------------------------------------------------------
.pgdata/
postgres-data/
postgres-data*/
pgdata/
pgdata*/

# ------------------------------------------------------------
# Docker/local container files, if Codex adds them later
# Keep Dockerfile and docker-compose files committed unless they contain secrets.
# ------------------------------------------------------------
.docker/

# ------------------------------------------------------------
# Test and tooling artifacts
# ------------------------------------------------------------
playwright-report/
test-results/
.cypress/
cypress/videos/
cypress/screenshots/

# ------------------------------------------------------------
# Package manager artifacts
# Lock files should normally be committed for reproducible installs.
# Do not ignore package-lock.json, pnpm-lock.yaml, yarn.lock, or bun.lockb.
# ------------------------------------------------------------
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
.yarn-integrity

# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------
# Editor and IDE files
# ------------------------------------------------------------
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.example.json
*.swp
*.swo
*~

# ------------------------------------------------------------
# Azure/local deployment artifacts
# ------------------------------------------------------------
.azure/
.azurefunctions/
.localsettings.json
local.settings.json

# ------------------------------------------------------------
# OpenAI / AI tooling local state, if generated
# ------------------------------------------------------------
.openai/
.codex/cache/
.codex/logs/
